---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import {FacebookIcon,InstagramIcon,WhatsAppIcon} from '../assets/images/contact-icons';
import { Image } from 'astro:assets';
import logoChico from '../assets/images/logo_chico.jpeg';
---

<header>
	<nav>
        <h2>
            <a href="/" style="display: flex; align-items: center; gap: 10px;">
                <Image 
                    src={logoChico} 
                    alt="Logo Psiique & Soma" 
                    width={48} 
                    height={48} 
                    class="logo-cuadrito"
                />
                {SITE_TITLE}
            </a>
        </h2>
		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Servicios</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.facebook.com/share/1EeGNA5NXM/" target="_blank">
				<span class="sr-only">Goes to facebook's page</span>
				<FacebookIcon />
			</a>
			<a href="https://www.instagram.com/psiiquesoma?igsh=MTkxdHVmcXRranAz" target="_blank">
				<span class="sr-only">Follow Psiique & Soma on Instagram</span>
				<InstagramIcon />
			</a>
			<a href="https://wa.me/+523317589990" target="_blank">
				<span class="sr-only">Contact us on WhatsApp</span>
				<WhatsAppIcon />
			</a>
		</div>
	</nav>
</header>
<style>
    header {
        margin: 0;
        padding: 0 1em;
        background: white;
        box-shadow: 0 2px 8px rgba(var(--black), 5%);
    }
    h2 {
        margin: 0;
        font-size: 1.2em; /* Un poco más grande para que resalte el nombre de la clínica */
    }

    h2 a,
    h2 a.active {
        text-decoration: none;
        color: var(--black); /* Asegura que el título mantenga un color sólido */
    }
    
    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 4em; /* Asegura un área táctil cómoda */
    }
    
    .internal-links {
        display: flex;
        gap: 1em; /* Separa los enlaces uniformemente en PC */
    }

    nav a {
        padding: 1em 0.5em;
        color: var(--black);
        border-bottom: 4px solid transparent;
        text-decoration: none;
        font-weight: 500;
    }
    
    nav a.active {
        text-decoration: none;
        border-bottom-color: var(--accent);
    }
    
    .social-links {
        display: flex;
        gap: 0.5em; /* Separa los íconos sociales */
    }
    
    .social-links a {
        display: flex;
        padding: 0.5em; /* Área táctil más grande para los íconos */
    }

    /* === MAGIA RESPONSIVA PARA CELULARES === */
    @media (max-width: 720px) {
        nav {
            flex-direction: column; /* Apila el título y los links verticalmente */
            justify-content: center;
            padding: 1em 0;
        }
        
        .internal-links {
            margin-top: 0.5em;
            flex-wrap: wrap; /* Si la pantalla es muy muy pequeña, los links bajan de línea solos */
            justify-content: center;
            gap: 0.5em; /* Reduce un poco la separación en celular */
        }
        
        nav a {
            padding: 0.5em; /* Reduce el padding vertical en celular para ahorrar espacio */
        }

        .social-links {
            display: none; /* Excelente decisión ocultarlos en móvil para limpiar la interfaz */
        }
    }
</style>
